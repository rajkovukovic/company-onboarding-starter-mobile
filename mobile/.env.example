# Optional. If unset, the app auto-detects your dev machine's IP from Expo
# (works in iOS Simulator, Android Emulator, and Expo Go on a physical device
# on the same WiFi). Override here if your backend lives somewhere else.
# EXPO_PUBLIC_API_URL=http://192.168.1.10:3001

# Get your API key from https://developer.company-information.service.gov.uk
COMPANIES_HOUSE_API_KEY=

# Get your OpenAI API key from https://platform.openai.com/account/api-keys
OPENAI_API_KEY=

# Add other API keys as needed